generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── NextAuth required models ─────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Application models ───────────────────────────────────────────────────────

model User {
  id               String                  @id @default(cuid())
  name             String?
  email            String?                 @unique
  emailVerified    DateTime?
  image            String?
  accounts         Account[]
  sessions         Session[]
  folders          Folder[]
  bookmarks        Bookmark[]
  presets          UserPreset[]
  preferences      UserPreference[]
  extensionTokens  ExtensionToken[]
  oauthCodes       OAuthAuthorizationCode[]
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
}

enum PresetType {
  TAG
  ICON
  FAVICON_CACHE
}

model UserPreset {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      PresetType
  value     String     @db.VarChar(500)
  createdAt DateTime   @default(now())

  @@unique([userId, type, value])
  @@index([userId, type])
}

model UserPreference {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  key    String @db.VarChar(255)
  value  String @db.VarChar(5000)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, key])
  @@index([userId])
}

model Folder {
  id        String     @id @default(cuid())
  name      String     @db.VarChar(100)
  userId    String
  parentId  String?
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent    Folder?    @relation("FolderHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children  Folder[]   @relation("FolderHierarchy")
  bookmarks Bookmark[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  // Max 2 levels enforced in application logic, not DB
  @@unique([userId, parentId, name])
  @@index([userId])
  @@index([parentId])
}

model Bookmark {
  id           String    @id @default(cuid())
  url          String    @db.VarChar(2048)
  title        String    @db.VarChar(500)
  tags         String[]
  icon         String?
  reminderDate DateTime?
  lastAccessed DateTime?
  folderId     String?
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  folder       Folder?   @relation(fields: [folderId], references: [id], onDelete: SetNull)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // One bookmark per URL per user
  @@unique([userId, url])
  @@index([userId])
  @@index([userId, createdAt(sort: Desc)])
  @@index([folderId])
  @@index([reminderDate])
}

// Long-lived refresh token issued to Chrome extension
// Short-lived JWT access tokens are derived from this token via POST /api/extension/refresh
model ExtensionToken {
  id        String    @id @default(cuid())
  token     String    @unique @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  label     String    @default("Chrome Extension")
  scopes    String[]  @default([])
  lastUsed  DateTime?
  createdAt DateTime  @default(now())
  expiresAt DateTime

  @@index([userId])
}

// OAuth 2.0 Authorization Code — one-time use, 10-minute TTL
// Used in the Authorization Code Flow + PKCE for the Chrome extension
model OAuthAuthorizationCode {
  id                  String    @id @default(cuid())
  code                String    @unique
  userId              String
  clientId            String
  redirectUri         String
  scopes              String[]
  codeChallenge       String
  codeChallengeMethod String    @default("S256")
  state               String
  expiresAt           DateTime
  usedAt              DateTime?
  createdAt           DateTime  @default(now())
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([code])
  @@index([userId])
  @@map("oauth_authorization_codes")
}
