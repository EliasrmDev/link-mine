# Database
# For local development (Docker):
DATABASE_URL="postgresql://username:password@localhost:5432/linkmine"
DIRECT_URL="postgresql://username:password@localhost:5432/linkmine"
#
# For Supabase:
# DATABASE_URL uses the connection pooler (port 6543, transaction mode)
# DIRECT_URL uses the direct connection (port 5432, needed for migrations)
# DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# Authentication
NEXTAUTH_SECRET="your-nextauth-secret-here"
AUTH_SECRET="your-nextauth-secret-here"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Microsoft OAuth (optional)
AUTH_MICROSOFT_ENTRA_ID_ID="your-microsoft-client-id"
AUTH_MICROSOFT_ENTRA_ID_SECRET="your-microsoft-client-secret"
AUTH_MICROSOFT_ENTRA_ID_ISSUER="https://login.microsoftonline.com/tenant-id/v2.0"

# Search Engine Verification (optional)
GOOGLE_VERIFICATION="your-google-site-verification-code"
BING_VERIFICATION="your-bing-verification-code"
YANDEX_VERIFICATION="your-yandex-verification-code"

# Analytics (optional)
GOOGLE_ANALYTICS_ID="G-XXXXXXXXXX"
GTM_ID="GTM-XXXXXXX"

# Extension API
EXT_API_SECRET="your-extension-api-secret"