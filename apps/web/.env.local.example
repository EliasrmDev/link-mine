# Database
DATABASE_URL="postgresql://username:password@localhost:5432/linkmine"

# Authentication
NEXTAUTH_SECRET="your-nextauth-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Microsoft OAuth (optional)
MICROSOFT_CLIENT_ID="your-microsoft-client-id"
MICROSOFT_CLIENT_SECRET="your-microsoft-client-secret"

# Search Engine Verification (optional)
GOOGLE_VERIFICATION="your-google-site-verification-code"
BING_VERIFICATION="your-bing-verification-code"
YANDEX_VERIFICATION="your-yandex-verification-code"

# Analytics (optional)
GOOGLE_ANALYTICS_ID="G-XXXXXXXXXX"
GTM_ID="GTM-XXXXXXX"

# Extension API
EXT_API_SECRET="your-extension-api-secret"